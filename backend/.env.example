# ============================================================================
# MLIMS Backend — Environment Variables
# Copy to .env and fill in real values. Never commit .env to version control.
# ============================================================================

# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── PostgreSQL — shared connection settings ─────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mlims

# Per-role connection credentials (matches Phase 1 demo users)
DB_USER_ADMIN=demo_admin
DB_PASS_ADMIN=Admin@MLIMS2024

DB_USER_DOCTOR=demo_doctor
DB_PASS_DOCTOR=Doctor@MLIMS2024

DB_USER_FORENSIC=demo_forensic
DB_PASS_FORENSIC=Forensic@MLIMS2024

DB_USER_POLICE=demo_police
DB_PASS_POLICE=Police@MLIMS2024

DB_USER_COURT=demo_court
DB_PASS_COURT=Court@MLIMS2024

DB_USER_CLERK=demo_clerk
DB_PASS_CLERK=Clerk@MLIMS2024

DB_USER_AUDITOR=demo_auditor
DB_PASS_AUDITOR=Auditor@MLIMS2024

# ── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace-with-a-64-char-random-hex-string
JWT_REFRESH_SECRET=replace-with-a-different-64-char-random-hex-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Encryption (AES-256-GCM for PII columns) ───────────────────────────────
# 32-byte key as 64 hex characters
AES_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
HMAC_SECRET_KEY=replace-with-a-64-char-hmac-secret-key-hex-string

# ── File Uploads ────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
